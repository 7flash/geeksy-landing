# Geeksy Landing — example environment
# Copy to .env (local) or set equivalent process env on the server.

# App
BUN_PORT=3400

# Wheel challenge / reward behavior
MIN_GRAVITY_TO_SPIN=1
WHEEL_CHALLENGE_TTL_MS=300000
CLAIM_CHALLENGE_TTL_MS=600000

# Treasury source mode
# Use "env" for fixed treasury basis or "command" for live command-driven snapshots.
TREASURY_SOURCE=env
TREASURY_AMOUNT=0
TREASURY_SNAPSHOT_COMMAND=

# Live treasury snapshot inputs (used by scripts/treasury-snapshot.ts)
TREASURY_WALLET=
TREASURY_ASSET=SOL
TREASURY_TOKEN_MINT=
TREASURY_TOKEN_SYMBOL=SOL
TREASURY_RPC_URL=
HELIUS_RPC_URL=

# Payout worker integration
TREASURY_PAYOUT_COMMAND=
PAYOUT_ACTION=list
PAYOUT_WATCH=false
PAYOUT_INTERVAL_MS=30000
PAYOUT_DRY_RUN=true
PAYOUT_BATCH_LIMIT=20

# Admin settlement
WHEEL_ADMIN_TOKEN=

# Known wallet labels (optional)
KNOWN_WALLETS_PATH=
GKSY_TREASURY_WALLET=
GKSY_TEAM_WALLET=
GKSY_BONDING_CURVE_WALLET=
GKSY_EXCHANGE_WALLET=
GKSY_LP_WALLET=
GKSY_INTERNAL_WALLET=
